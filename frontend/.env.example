# Copy to `.env` and adjust as needed. Vite only exposes vars prefixed VITE_.

# Base URL the frontend uses for API calls.
#  - Leave as "/api" to go through the Vite dev proxy (see vite.config.ts) or a
#    production reverse proxy on the same origin (recommended).
#  - Or set an absolute URL to hit the backend directly, e.g.
#    VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_BASE_URL=/api

# Where the Vite dev proxy forwards /api requests (dev only).
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
